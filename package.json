{
    "name": "FastShot",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "start": "nodemon --ext js,css,html --exec electron .",
        "test": "echo \"Error: no test specified\" && exit 1",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.yunextexpressit",
        "productName": "FastShot",
        "files": [
            "**/*"
        ],
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "assets/camera.ico"
        },
        "nsis": {
            "installerIcon": "assets/camera.ico",
            "uninstallerIcon": "assets/camera.ico",
            "installerHeaderIcon": "assets/camera.ico"
        }
    },
    "keywords": [],
    "author": "Taiwo Hassan",
    "license": "ISC",
    "description": "Screenshot made easy",
    "devDependencies": {
        "electron": "^41.0.3",
        "electron-builder": "^26.8.1",
        "nodemon": "^3.1.14"
    }
}